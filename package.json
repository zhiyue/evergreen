{
  "name": "evergreen",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test --import tsx",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "ci:security": "npm audit --omit=dev --audit-level=moderate",
    "ci:dry-run": "wrangler deploy --dry-run",
    "import-cache": "node scripts/import-cache.mjs",
    "enable-access": "node scripts/enable-access.mjs",
    "setup-access": "node scripts/setup-access.mjs",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev"
  },
  "dependencies": {
    "jose": "^6.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.0",
    "@types/node": "^25.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.92.0"
  }
}
